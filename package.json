{
  "name": "packed-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start -c",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test scripts",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "dev:site": "bun run build:rnw-css && bun run --cwd site dev",
    "registry:generate": "bun run scripts/generate-registry-items.ts",
    "build:registry": "bun run scripts/generate-registry-items.ts && bun run scripts/merge-registry-items.ts && bun run scripts/build-registry.ts && bun run scripts/validate-registry.ts",
    "registry:validate": "bun run scripts/validate-registry.ts",
    "sync:site-registry": "bun run scripts/sync-site-registry.ts",
    "build:rnw-css": "bun run scripts/build-rnw-css.ts",
    "theme:build": "bun run scripts/build-theme.ts",
    "build:site": "bun run build:registry && bun run sync:site-registry && bun run build:rnw-css && bun run --cwd site build",
    "clean": "rm -rf .expo node_modules site/node_modules site/.next site/out"
  },
  "dependencies": {
    "@expo-google-fonts/dm-mono": "^0.4.2",
    "@expo-google-fonts/figtree": "^0.4.1",
    "@expo-google-fonts/lora": "^0.4.2",
    "@rn-primitives/accordion": "^1.5.2",
    "@rn-primitives/alert-dialog": "^1.5.2",
    "@rn-primitives/aspect-ratio": "^1.5.2",
    "@rn-primitives/avatar": "^1.5.2",
    "@rn-primitives/checkbox": "^1.5.2",
    "@rn-primitives/collapsible": "^1.5.2",
    "@rn-primitives/dialog": "^1.5.2",
    "@rn-primitives/dropdown-menu": "^1.5.2",
    "@rn-primitives/label": "^1.5.2",
    "@rn-primitives/popover": "^1.5.2",
    "@rn-primitives/portal": "~1.5.2",
    "@rn-primitives/progress": "^1.5.2",
    "@rn-primitives/radio-group": "^1.5.2",
    "@rn-primitives/select": "^1.5.2",
    "@rn-primitives/separator": "^1.5.2",
    "@rn-primitives/slot": "^1.5.2",
    "@rn-primitives/switch": "^1.5.2",
    "@rn-primitives/tabs": "^1.5.2",
    "@rn-primitives/toggle": "^1.5.2",
    "@rn-primitives/toggle-group": "^1.5.2",
    "@rn-primitives/tooltip": "^1.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.13",
    "expo-constants": "~56.0.19",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.12",
    "expo-splash-screen": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^1.21.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.10",
    "eslint": "^9",
    "eslint-config-expo": "^57.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
